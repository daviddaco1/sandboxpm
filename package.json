{
  "name": "sandboxpm",
  "private": true,
  "version": "0.1.1",
  "description": "Secure, zero-trust package manager with content-addressable store",
  "license": "MIT",
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "SANDBOXPM_E2E=1 vitest run packages/cli/src/install.e2e.test.ts",
    "test:docker": "DOCKER_INTEGRATION=1 vitest run packages/scripts/src/docker.integration.test.ts",
    "lint": "eslint packages/*/src/**/*.ts",
    "clean": "rimraf packages/*/dist packages/*/*.tsbuildinfo",
    "sync-assets": "node scripts/sync-docker-assets.mjs",
    "sync-assets:check": "node scripts/sync-docker-assets.mjs --check"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^9.0.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.4.0",
    "vite": "^6.4.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
