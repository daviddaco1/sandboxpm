{
  "name": "sandboxpm",
  "version": "0.1.2",
  "description": "A security-first, zero-trust package manager for Node.js — never runs install scripts without consent.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/daviddaco1/sandboxpm.git",
    "directory": "packages/cli"
  },
  "homepage": "https://sandboxpm.andresodev.com",
  "bugs": "https://github.com/daviddaco1/sandboxpm/issues",
  "type": "module",
  "bin": {
    "sandboxpm": "./dist/bin.js",
    "sbnpm": "./dist/bin.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "!dist/**/*.tsbuildinfo"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc --build",
    "test": "vitest run",
    "dev": "node --loader ts-node/esm src/bin.ts"
  },
  "dependencies": {
    "@sandboxpm/config": "workspace:*",
    "@sandboxpm/store": "workspace:*",
    "@sandboxpm/fetcher": "workspace:*",
    "@sandboxpm/resolver": "workspace:*",
    "@sandboxpm/linker": "workspace:*",
    "@sandboxpm/scripts": "workspace:*",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "dockerode": "^4.0.0",
    "ora": "^8.0.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "semver": "^7.6.0"
  },
  "devDependencies": {
    "@types/dockerode": "^3.3.29",
    "@types/pino": "^7.0.0",
    "@types/semver": "^7.5.8"
  }
}
